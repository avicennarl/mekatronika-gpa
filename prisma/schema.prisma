generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CourseType {
  TEORI
  PRAKTIK
}

model Course {
  id        String     @id @default(cuid())
  semester  Int
  kode      String
  nama      String
  sks       Int
  type      CourseType
  active    Boolean    @default(true)
  order     Int        @default(0)

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([semester, type])
}